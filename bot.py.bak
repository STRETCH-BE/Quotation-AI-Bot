    async def status_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle /status command - ENHANCED WITH ENTRA ID AND DYNAMICS STATUS"""
        db_connected = "✅ Connected" if self.db.test_connection() else "âŒ Disconnected"
        
        # Get AI status
        ai_status = self.ai_manager.get_status()
        ai_display = "✅ Active" if ai_status["client_initialized"] else "âš ï¸ Fallback Mode"
        
        # Test Entra ID email - FIX: Properly handle the synchronous method
        email_status = "âŒ Disabled"
        if Config.ENABLE_EMAIL_SENDING:
            try:
                # Since test_connection is synchronous in EntraIDEmailSender, we can call it directly
                email_test = self.email_sender.test_connection()
                email_status = "✅ Connected (Entra ID)" if email_test else "âš ï¸ Connection Failed"
            except Exception as e:
                logger.error(f"Error testing email connection: {e}")
                email_status = "âš ï¸ Error testing connection"
        
        # Dynamics 365 status
        dynamics_status = "âŒ Disabled"
        dynamics_sync_active = "No"
        if Config.ENABLE_DYNAMICS_SYNC:
            try:
                dynamics_test = await self.dynamics_integration.test_connection()
                dynamics_status = "✅ Connected" if dynamics_test else "âš ï¸ Connection Failed"
                
                # Check if background sync is running
                if self.dynamics_sync_task and not self.dynamics_sync_task.done():
                    dynamics_sync_active = "Yes (Bidirectional)"
            except Exception as e:
                logger.error(f"Error testing Dynamics connection: {e}")
                dynamics_status = "âš ï¸ Error testing connection"
        
        # Get some statistics
        ceiling_count = self.db.execute_query(
            "SELECT COUNT(*) as count FROM products WHERE base_category = 'ceiling'", fetch=True
        )
        
        # Get type_ceiling variations
        type_variations = self.db.execute_query(
            """
            SELECT product_type, COUNT(DISTINCT type_ceiling) as variations
            FROM products
            WHERE base_category = 'ceiling'
            AND type_ceiling IS NOT NULL
            GROUP BY product_type
            """,
            fetch=True,
        )
        
        # Get user statistics
        user_stats = self.db.execute_query(
            """
            SELECT
                COUNT(DISTINCT user_id) as total_users,
                COUNT(DISTINCT CASE WHEN created_at > DATE_SUB(NOW(), INTERVAL 7 DAY) THEN user_id END) as active_users
            FROM conversation_logs
            """,
            fetch=True,
        )
        
        # Check for active edit sessions
        edit_sessions_count = len(self.quote_editor.edit_sessions) if hasattr(self.quote_editor, 'edit_sessions') else 0
        
        # Build status message without Markdown
        status_msg = "ðŸ”§ System Status - v8.7 WITH USER MANAGEMENT, FIXED QUOTE EDITING & DYNAMICS 365\n\n"
        status_msg += f"Database: {db_connected}\n"
        status_msg += f"AI Assistant: {ai_display}\n"
        status_msg += f"Email Service: {email_status}\n"
        status_msg += f"Dynamics 365: {dynamics_status}\n"
        status_msg += f"Background Sync: {dynamics_sync_active}\n"
