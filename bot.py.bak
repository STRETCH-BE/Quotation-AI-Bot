    def _get_uptime(self):
        """Calculate bot uptime"""
        if hasattr(self, 'start_time'):
            uptime = datetime.now() - self.start_time
            days = uptime.days
            hours, remainder = divmod(uptime.seconds, 3600)
            minutes, seconds = divmod(remainder, 60)
            
            parts = []
            if days:
                parts.append(f"{days}d")
            if hours:
                parts.append(f"{hours}h")
            if minutes:
                parts.append(f"{minutes}m")
            parts.append(f"{seconds}s")
            
            return " ".join(parts)
        return "Unknown"
    
    async def handle_message(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle all messages - with user management and Dynamics support"""
        user_id = update.effective_user.id
        message_text = update.message.text
        
        # Log incoming message for debugging
        logger.debug(f"Received message from {user_id}: {message_text}")
        
        # Check if we're in an active conversation handler
        # This is important - conversation handlers should take precedence
        
        # PRIORITY 0: Check if admin is adding a note
        if context.user_data.get('admin_adding_note_for'):
            target_user_id = context.user_data['admin_adding_note_for']
            success = self.db.add_user_note(target_user_id, message_text, user_id)
            
            if success:
                await update.message.reply_text("✅ Note added successfully!")
            else:
                await update.message.reply_text("âŒ Failed to add note.")
            
            del context.user_data['admin_adding_note_for']
            return
        
        # PRIORITY 0.5: Check if admin is in search mode
        if context.user_data.get('admin_search_mode') and user_id in Config.ADMIN_USER_IDS:
            await self.admin_user_mgmt.handle_search_input(update, context)
            return
        
        # Check if waiting for Dynamics sync input
        if context.user_data.get('awaiting_dynamics_user_id'):
            try:
                user_id_to_sync = int(message_text)
                await update.message.reply_text(f"ðŸ”„ Syncing user {user_id_to_sync}...")
                success, message = await self.dynamics_integration.manual_sync_user(user_id_to_sync)
                await update.message.reply_text(f"{'✅' if success else 'âŒ'} {message}")
            except ValueError:
                await update.message.reply_text("âŒ Invalid user ID. Please enter a number.")
            
            del context.user_data['awaiting_dynamics_user_id']
            return
        
        if context.user_data.get('awaiting_dynamics_quote_id'):
            try:
                quote_id_to_sync = int(message_text)
                await update.message.reply_text(f"ðŸ”„ Syncing quote {quote_id_to_sync}...")
                success, message = await self.dynamics_integration.manual_sync_quote(quote_id_to_sync)
                await update.message.reply_text(f"{'✅' if success else 'âŒ'} {message}")
            except ValueError:
                await update.message.reply_text("âŒ Invalid quote ID. Please enter a number.")
            
            del context.user_data['awaiting_dynamics_quote_id']
            return
        
        # Handle Dynamics menu selections
        if context.user_data.get('admin_dynamics_menu'):
            await self.handle_dynamics_menu_selection(update, context)
            return
        
        # PRIORITY 1: Check for active quote creation session
        session = self.db.get_quote_session(user_id)
        if session:
            logger.info(f"User {user_id} has active quote session")
            await self.quote_flow.handle_message(update, context)
            return
        
        # PRIORITY 2: Check for admin menu selections including Dynamics
        if user_id in Config.ADMIN_USER_IDS and message_text in [
            "📨 Send Messages", "📊 View Statistics", "👥 User Management", 
            "📊 Dynamics 365 Sync", "🔧 System Diagnostics", "❌ Exit Admin Mode",
            "📋 List All Users", "🔍 Search Users", "📊 User Statistics",
            "👥 User Groups", "📤 Export User Data", "🏷️ Manage Tags",
            "⬅️ Back to Admin Menu", "Search by Name", "Search by Email",
            "Search by Company", "Search by Phone", "Show Companies Only",
            "Show B2B Users", "Show Active Users", "Show With Quotes",
            "🔄 Sync Pending Items", "🔍 View Sync Errors", "👤 Sync Specific User",
            "🔄 Sync Specific Quote", "🔄 Force Full Sync"
        ]:
            # Exit AI chat mode if active
            if context.user_data.get("ai_chat_mode", False):
                context.user_data["ai_chat_mode"] = False
                logger.info(f"Exiting AI chat mode for admin command: {message_text}")
            
            await self.handle_admin_menu(update, context)
            return
        
        # PRIORITY 3: Check if message is a command
        if message_text.startswith("/"):
            if context.user_data.get("ai_chat_mode", False):
                context.user_data["ai_chat_mode"] = False
                logger.info(f"Exiting AI chat mode for command: {message_text}")
            return
        
        # PRIORITY 4: Check if in AI chat mode
        if Config.ENABLE_AI_CHAT and context.user_data.get("ai_chat_mode", False):
            logger.info(f"User {user_id} is in AI chat mode")
            await self.conversational_handler.handle_ai_response(update, context)
            return
        
        # PRIORITY 5: Default response
        logger.info(f"No active session for user {user_id}, showing default message")
        
        keyboard = [
            [InlineKeyboardButton("📋 Create Quote", callback_data="cmd_create_quote")],
            [InlineKeyboardButton("📊 View Quotes", callback_data="cmd_quotes")],
            [InlineKeyboardButton("ðŸ¤– Ask AI Assistant", callback_data="cmd_ask_ai")],
            [InlineKeyboardButton("ðŸ‘¤ My Profile", callback_data="cmd_profile")],
            [InlineKeyboardButton("â“ Help", callback_data="cmd_help")]
        ]
        reply_markup = InlineKeyboardMarkup(keyboard)
        
        await update.message.reply_text(
            "ðŸ‘‹ Hi! I'm your intelligent assistant.\n\n"
            "What would you like to do?",
            reply_markup=reply_markup
        )
    
    async def handle_inline_commands(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle inline button commands - includes profile"""
        query = update.callback_query
        await query.answer()
        
        user_id = query.from_user.id
        
        # Check for active quote session
        session = self.db.get_quote_session(user_id)
        
        if query.data == "cmd_create_quote":
            if session:
                await query.message.reply_text(
                    "âš ï¸ You already have an active quote creation session.\n"
                    "Please complete or cancel it first.\n\n"
                    "Use /cancel to end the current session."
                )
            else:
                await self.create_quote_command(update, context)
        
        elif query.data == "cmd_quotes":
            if session:
                # Warn about active session but still show quotes
                await query.message.reply_text(
                    "âš ï¸ Note: You have an active quote creation session.\n"
                    "Showing your existing quotes..."
                )
            await self.quotes_command(update, context)
        
        elif query.data == "cmd_ask_ai":
            if session:
                await query.message.reply_text(
                    "âš ï¸ You have an active quote session. "
                    "You can still use the AI assistant, but consider completing your quote first."
                )
            await self.ask_question_command(update, context)
        
        elif query.data == "cmd_profile":
            await self.profile_command(update, context)
        
        elif query.data == "cmd_help":
            await self.help_command(update, context)
    
    async def shutdown(self, application):
        """Cleanup on shutdown"""
        if self.dynamics_sync_task and not self.dynamics_sync_task.done():
            logger.info("Stopping Dynamics 365 sync task...")
            self.dynamics_sync_task.cancel()
            try:
                await self.dynamics_sync_task
            except asyncio.CancelledError:
                pass
        logger.info("Shutdown complete")
    
