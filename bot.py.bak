        if Config.ENABLE_DYNAMICS_SYNC:
            logger.info("📊 Dynamics 365: ENABLED - Bidirectional sync active")
            logger.info("  - Users sync to Contacts/Accounts")
            logger.info("  - Quotes sync bidirectionally")
            logger.info("  - Background sync every 5 minutes")
        
        try:
            # Validate configuration
            Config.validate_config()
            
            # Test database and create admin tables
            if not self.db.test_connection():
                logger.error("âŒ Cannot connect to database!")
                return
            
            # Add admin messaging tables
            add_admin_messaging_tables(self.db)
            
            # Run diagnostics
            if Config.DEBUG_MODE:
                self.db.run_diagnostics()
            
            # Create application
            application = Application.builder().token(Config.BOT_TOKEN).build()
            
            # Make bot components accessible to handlers
            application.bot_data['quote_editor'] = self.quote_editor
            application.bot_data['quote_flow'] = self.quote_flow
            application.bot_data['db'] = self.db
            application.bot_data['email_sender'] = self.email_sender
            application.bot_data['pdf_generator'] = self.pdf_generator if Config.ENABLE_PDF_GENERATION else None
            application.bot_data['dynamics_integration'] = self.dynamics_integration
                        
            # Add startup handler
            async def post_init(application):
                await self.startup_tasks()
            
            application.post_init = post_init
            application.post_shutdown = self.shutdown
            
            # IMPORTANT: Order matters! Conversation handlers must be added before generic handlers
            
            # Add onboarding conversation handler FIRST with proper states
            onboarding_handler = ConversationHandler(
                entry_points=[
                    CommandHandler("start", self.start_command)
                ],
                states={
                    UserOnboardingHandler.ASK_FIRST_NAME: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_first_name)
                    ],
                    UserOnboardingHandler.ASK_LAST_NAME: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_last_name)
                    ],
                    UserOnboardingHandler.ASK_IS_COMPANY: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_is_company)
                    ],
                    UserOnboardingHandler.ASK_COMPANY_NAME: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_company_name)
                    ],
                    UserOnboardingHandler.ASK_VAT_NUMBER: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_vat_number)
                    ],
                    UserOnboardingHandler.ASK_ADDRESS: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_address)
                    ],
                    UserOnboardingHandler.ASK_EMAIL: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_email)
                    ],
                    UserOnboardingHandler.ASK_PHONE: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.ask_phone)
                    ],
                    UserOnboardingHandler.CONFIRM_DATA: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.handle_confirmation)
                    ],
                    UserOnboardingHandler.EDIT_FIELD: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.handle_edit_field)
                    ],
                    UserOnboardingHandler.EDIT_VALUE: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.handle_edit_value)
                    ],
                },
                fallbacks=[
                    CommandHandler("cancel", self.user_onboarding.cancel_onboarding)
                ],
                name="user_onboarding",
                persistent=False,
                per_message=False,
                allow_reentry=True  # Allow re-entering the conversation
            )
            
            application.add_handler(onboarding_handler)
            
            # Profile editing handler for existing users
            profile_edit_handler = ConversationHandler(
                entry_points=[
                    CallbackQueryHandler(self.user_onboarding.handle_profile_callback, pattern="^edit_profile$")
                ],
                states={
                    UserOnboardingHandler.EDIT_FIELD: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND & ~filters.Regex("^(✅ Save Changes|âŒ Cancel)$"), self.user_onboarding.handle_profile_edit),
                        MessageHandler(filters.Regex("^(✅ Save Changes|âŒ Cancel)$"), self.user_onboarding.handle_profile_edit)
                    ],
                    UserOnboardingHandler.EDIT_VALUE: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.user_onboarding.handle_edit_value)
                    ],
                },
                fallbacks=[
                    CommandHandler("cancel", self.user_onboarding.cancel_onboarding)
                ],
                name="profile_editing",
                persistent=False,
                per_message=False
            )
            
            application.add_handler(profile_edit_handler)
            
            # Add quote editing conversation handler
            quote_edit_handler = ConversationHandler(
                entry_points=[
                    CallbackQueryHandler(
                        self.quote_editor.start_quote_edit,
                        pattern="^quote_edit_\\d+$"
                    )
                ],
                states={
                    self.quote_editor.EDIT_MENU: [
                        CallbackQueryHandler(
                            self.quote_editor.handle_quote_callback,
                            pattern="^(edit_|quote_)"
                        )
                    ],
                    self.quote_editor.EDIT_DIMENSIONS: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, 
                                     self.quote_editor.handle_edit_input)
                    ],
                    self.quote_editor.EDIT_PERIMETER: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND,
                                     self.quote_editor.handle_edit_input)
                    ],
                    self.quote_editor.EDIT_COLOR: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND,
                                     self.quote_editor.handle_edit_input)
                    ],
                    self.quote_editor.EDIT_CORNERS: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND,
                                     self.quote_editor.handle_edit_input)
                    ],
                },
                fallbacks=[
                    CommandHandler("cancel", self.quote_editor.handle_cancel_edit),
                    CallbackQueryHandler(
                        self.quote_editor.cancel_edit,
                        pattern="^edit_cancel_\\d+$"
                    )
                ],
                name="quote_editing",
                persistent=False,
                per_message=False
            )
            
            application.add_handler(quote_edit_handler)
            
            # Add admin messaging conversation handler
            admin_conv_handler = ConversationHandler(
                entry_points=[
                    CommandHandler("send_message", self.admin_messaging.admin_message_command),
                    MessageHandler(filters.Regex("^📨 Send Messages"), self.admin_messaging.admin_message_command),
                ],
                states={
                    AdminMessagingSystem.MESSAGE_TYPE: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.admin_messaging.handle_message_type)
                    ],
                    AdminMessagingSystem.USER_SELECTION: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.admin_messaging.handle_user_selection),
                        CallbackQueryHandler(self.admin_messaging.handle_user_selection),
                    ],
                    AdminMessagingSystem.MESSAGE_INPUT: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.admin_messaging.handle_message_input)
                    ],
                    AdminMessagingSystem.CONFIRMATION: [
                        MessageHandler(filters.TEXT & ~filters.COMMAND, self.admin_messaging.handle_confirmation)
                    ],
                },
                fallbacks=[
                    CommandHandler("cancel", self.admin_messaging.cancel_handler),
                    MessageHandler(filters.Regex("^âŒ Cancel"), self.admin_messaging.cancel_handler),
                ],
                name="admin_messaging",
                persistent=False,
                per_message=False,
            )
            
            application.add_handler(admin_conv_handler)
            
            # Add command handlers - these don't interfere with conversation handlers
            application.add_handler(CommandHandler("profile", self.profile_command))
            application.add_handler(CommandHandler("create_quote", self.create_quote_command))
            application.add_handler(CommandHandler("quotes", self.quotes_command))
            application.add_handler(CommandHandler("ask_a_question", self.ask_question_command))
            application.add_handler(CommandHandler("help", self.help_command))
            application.add_handler(CommandHandler("status", self.status_command))
            application.add_handler(CommandHandler("admin", self.admin_command))
            
            # Add callback query handlers
            # Profile callbacks - exclude edit_profile as it's handled by conversation handler
            application.add_handler(CallbackQueryHandler(
                self.user_onboarding.handle_profile_callback,
                pattern="^(view_quotes|close_profile)$"
            ))
            
            # Admin user management callbacks
            application.add_handler(CallbackQueryHandler(
                self.admin_user_mgmt.handle_callback_query,
                pattern="^admin_(users_|user_|change_type_|set_type_|edit_user_|add_note_|manage_tags_|view_quotes_|view_activity_|send_msg_|export_user_|tag_add_|tag_remove_)"
            ))
            
            # Quote editor callbacks (excluding those handled by conversation handler)
            application.add_handler(CallbackQueryHandler(
                self.quote_editor.handle_quote_callback,
                pattern="^(quote_view_|quote_status_|status_change_|quote_pdf_|quote_email_|quote_list|quote_list_back)"
            ))
            
            # Inline command callbacks
            application.add_handler(CallbackQueryHandler(
                self.handle_inline_commands,
                pattern="^cmd_"
            ))
            
            # Add message handler - MUST BE LAST
            application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, self.handle_message))
            
            # Start bot
            logger.info("✅ Bot is running with COMPLETE USER MANAGEMENT SYSTEM & DYNAMICS 365...")
            logger.info("ðŸ‘¤ New users will go through onboarding automatically")
            logger.info("ðŸ“ User profiles stored with full information")
            logger.info("ðŸ§  AI remembers conversations and learns preferences")
            logger.info("ðŸ‘¥ Admins have full user management capabilities")
            logger.info("📊 Dynamics 365 CRM integration active")
            logger.info("ðŸ“ PERIMETER: Manual editing enabled for complex room shapes")
            logger.info("âœï¸ QUOTE EDITOR: Now using proper conversation handler")
            logger.info("✅ PRIORITY: Admin commands now work in AI chat mode")
            logger.info("✅ QUOTE EDITING: Fixed with proper state management")
            logger.info("✅ CALLBACK QUERIES: Now properly handled for all commands")
            logger.info("✅ ONBOARDING: Fixed to maintain conversation state properly")
            logger.info("✅ DYNAMICS 365: Bidirectional sync with CRM active")
            
            application.run_polling(allowed_updates=Update.ALL_TYPES)
        
        except Exception as e:
            logger.error(f"âŒ Failed to start bot: {e}")
            logger.error(traceback.format_exc())


# Entry point
if __name__ == "__main__":
