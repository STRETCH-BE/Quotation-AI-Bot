# Setup logging
setup_logging()
logger = logging.getLogger(__name__)

class EnhancedStretchCeilingBot:
    """Main bot class with all enhanced features including user management and Dynamics 365"""
    
    def __init__(self):
        self.version = "8.7"
        self.db = EnhancedDatabaseManager()
        # Use EnhancedAIChatManager directly
        self.ai_manager = EnhancedAIChatManager(self.db)
        self.quote_flow = EnhancedMultiCeilingQuoteFlow(self.db)
        self.quote_editor = QuoteEditor(self.db, self.quote_flow.calculator)
        self.conversational_handler = ConversationalBotHandler(self.db, self.ai_manager)
        self.admin_messaging = AdminMessagingSystem(self.db)
        
        # Add new handlers for user management
        self.user_onboarding = UserOnboardingHandler(self.db)
        self.admin_user_mgmt = AdminUserManagement(self.db)
        
        # Initialize Dynamics 365 integration
        self.dynamics_integration = Dynamics365IntegrationHandler(self.db)
        
        # Store reference for bidirectional sync task
        self.dynamics_sync_task = None
        
        # Set up email sender
        self.email_sender = EntraIDEmailSender()
        
        # Set up PDF generator if enabled
        if Config.ENABLE_PDF_GENERATION:
            self.pdf_generator = ImprovedStretchQuotePDFGenerator()
            # Pass the PDF generator to quote_editor
            self.quote_editor.pdf_generator = self.pdf_generator
        
        # Pass email sender to quote_editor
        if Config.ENABLE_EMAIL_SENDING:
            self.quote_editor.email_sender = self.email_sender
        
        # Store bot start time
        self.start_time = datetime.now()
    
    async def startup_tasks(self):
        """Run startup tasks including user management setup and Dynamics 365"""
        # Enhanced user tables are already created in EnhancedDatabaseManager.__init__()
        logger.info("📊 Enhanced user management tables already set up by database manager")
        
        # Scrape website data for AI context
        if Config.ENABLE_AI_CHAT:
            await self.ai_manager.scrape_website_data()
        
        # Test Entra ID email connection
        if Config.ENABLE_EMAIL_SENDING:
            logger.info("🔧 Testing Entra ID email connection...")
            try:
                # Use the async version since we're in an async context
                if await self.email_sender.test_connection_async():
                    logger.info("✅ Entra ID email connection successful")
                else:
                    logger.warning("âš ï¸ Entra ID email connection test failed")
            except Exception as e:
                logger.error(f"âŒ Error testing email connection: {e}")
                logger.warning("âš ï¸ Email service may not be available")
        
        # Test Dynamics 365 connection
        if Config.ENABLE_DYNAMICS_SYNC:
            logger.info("📊 Testing Dynamics 365 connection...")
            try:
                if await self.dynamics_integration.test_connection():
                    logger.info("✅ Dynamics 365 connection successful")
                    
                    # Start background sync task for bidirectional sync
                    self.dynamics_sync_task = asyncio.create_task(
                        self.dynamics_integration.periodic_sync_task()
                    )
                    logger.info("ðŸ”„ Started Dynamics 365 bidirectional sync task")
                    
                    # Sync any pending items
                    asyncio.create_task(self.dynamics_integration.sync_pending_entities())
                else:
                    logger.warning("âš ï¸ Dynamics 365 connection test failed")
            except Exception as e:
                logger.error(f"âŒ Error testing Dynamics connection: {e}")
    
    async def start_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Enhanced start command with onboarding check"""
        user = update.effective_user
        logger.info(f"ðŸ‘¤ User {user.id} ({user.first_name}) started the bot")
        
        # Check if user has completed onboarding
        user_profile = self.db.get_user_profile(user.id)
        
        if not user_profile or not user_profile.get('onboarding_completed'):
            # Start onboarding for new users - this returns the state
            return await self.user_onboarding.start_onboarding(update, context)
        
        # For existing users, show personalized welcome
        is_admin = user.id in Config.ADMIN_USER_IDS
        admin_text = " (Admin Mode)" if is_admin else ""
        
        # Get user's name from profile
        user_name = user_profile.get('first_name', user.first_name)
        company_info = ""
        if user_profile.get('is_company'):
            company_info = f"\nðŸ¢ Company: {user_profile['company_name']}"
        
        # Get AI status for display
        ai_status = "ðŸ¤– AI Assistant: Available" if self.ai_manager.client else "ðŸ¤– AI Assistant: Fallback Mode"
        
        # Get Dynamics sync status
        dynamics_info = ""
        if Config.ENABLE_DYNAMICS_SYNC:
            dynamics_ids = self.db.get_user_dynamics_ids(user.id)
            if dynamics_ids.get('contact_id'):
                dynamics_info = "\n📊 Dynamics 365: ✅ Synced"
            else:
                dynamics_info = "\n📊 Dynamics 365: â³ Pending sync"
        
        welcome_message = f"""ðŸ  Welcome back to {Config.COMPANY_NAME}, {user_name}!{admin_text}{company_info}

I remember you! Here's what you can do:

📋 Quote Creation
â€¢ /create_quote - Start a new multi-ceiling quote
â€¢ /quotes - View and manage your quotes

ðŸ¤– AI Assistant
â€¢ /ask_a_question - Chat with our AI assistant
â€¢ I remember our past conversations!
{ai_status}

ðŸ‘¤ Profile Management
â€¢ /profile - View and edit your profile
â€¢ Your client type: {user_profile.get('client_group', 'price_b2c').replace('price_', '').upper()}

🔧 Email & PDFs
â€¢ Quotes automatically include your information
â€¢ Professional PDFs with your details
â€¢ Email delivery via Microsoft
{dynamics_info}

ðŸ”§ Other Commands
â€¢ /help - Detailed help and support
â€¢ /status - Check system status"""
        
        if is_admin:
            welcome_message += """

ðŸ‘” Admin Commands
â€¢ /admin - Admin control panel
â€¢ /send_message - Send messages to users
â€¢ Manage users and view statistics
â€¢ Dynamics 365 sync management"""
        
        welcome_message += """

Ready to continue? Try /create_quote or /ask_a_question!"""
        
        await update.message.reply_text(welcome_message)
        
        # Log the interaction
        self.ai_manager.log_conversation(user.id, "user", "/start")
        self.ai_manager.log_conversation(user.id, "bot", welcome_message)
        
        # Important: Return ConversationHandler.END to indicate we're not in onboarding
        return ConversationHandler.END
    
    async def profile_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Show user profile - works with both messages and callback queries"""
        await self.user_onboarding.show_user_profile(update, context)
    
    async def create_quote_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle /create_quote command with onboarding check - works with both messages and callback queries"""
        user_profile = self.db.get_user_profile(update.effective_user.id)
        
        # Determine how to send the response
        if update.callback_query:
            message_func = update.callback_query.message.reply_text
        else:
            message_func = update.message.reply_text
        
        if not user_profile or not user_profile.get('onboarding_completed'):
            await message_func(
                "Please complete your profile first before creating a quote.\n"
                "Use /start to begin the registration process."
            )
            return
        
        # For callback queries, we need to handle this differently
        if update.callback_query:
            # Create a new message to start the quote flow
            await message_func("Starting quote creation...")
            # The quote flow expects a message, so we'll need to handle this specially
            update._effective_message = update.callback_query.message
        
        await self.quote_flow.start_quote_flow(update, context)
    
    async def quotes_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle /quotes command - works with both messages and callback queries"""
        # Check if user has an active quote session and warn them
        user_id = update.effective_user.id
        session = self.db.get_quote_session(user_id)
        
        if session and update.message:  # Only show warning for regular command, not callback
            await update.message.reply_text(
                "âš ï¸ You have an active quote creation session.\n"
                "Your progress has been saved. You can continue it later or use /cancel to end it.\n\n"
                "Showing your existing quotes..."
            )
        
        await self.quote_editor.show_user_quotes(update, context)
    
    async def ask_question_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle /ask_a_question command - works with both messages and callback queries"""
        if Config.ENABLE_AI_CHAT:
            await self.conversational_handler.handle_ai_question(update, context)
        else:
            # Handle both Update and CallbackQuery objects
            if update.callback_query:
                await update.callback_query.message.reply_text(
                    "AI chat is currently disabled. Please contact support for assistance."
                )
            elif update.message:
                await update.message.reply_text(
                    "AI chat is currently disabled. Please contact support for assistance."
                )
    
    async def admin_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle /admin command - show admin menu"""
        user_id = update.effective_user.id
        
        if user_id not in Config.ADMIN_USER_IDS:
            await update.message.reply_text("⛔ This command is for administrators only.")
            return
        
        keyboard = [
            ["📨 Send Messages"],
            ["📊 View Statistics"],
            ["👥 User Management"],
            ["📊 Dynamics 365 Sync"],
            ["🔧 System Diagnostics"],
            ["❌ Exit Admin Mode"],
        ]
        reply_markup = ReplyKeyboardMarkup(keyboard, one_time_keyboard=True, resize_keyboard=True)
        
        admin_menu = """👑 Admin Control Panel

Welcome to the admin interface. What would you like to do?

Available Options:
• 📨 Send Messages - Message users individually or broadcast
• 📊 View Statistics - See usage and performance stats
• 👥 User Management - Manage user permissions and data
• 📊 Dynamics 365 Sync - Manage CRM synchronization
• 🔧 System Diagnostics - Check system health

Select an option below:"""
        
        await update.message.reply_text(admin_menu, reply_markup=reply_markup)
    
    async def handle_admin_menu(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle admin menu selections with user management and Dynamics"""
        user_id = update.effective_user.id
        
        if user_id not in Config.ADMIN_USER_IDS:
            return
        
        message_text = update.message.text
        
        if message_text == "📨 Send Messages":
            return await self.admin_messaging.admin_message_command(update, context)
        
        elif message_text == "📊 View Statistics":
            await self.show_admin_statistics(update, context)
        
        elif message_text == "👥 User Management":
            await self.admin_user_mgmt.handle_user_management(update, context)
        
        elif message_text == "📊 Dynamics 365 Sync":
            await self.show_dynamics_sync_menu(update, context)
        
        elif message_text == "🔧 System Diagnostics":
            await self.status_command(update, context)
        
        elif message_text == "❌ Exit Admin Mode":
            await update.message.reply_text("Exited admin mode.", reply_markup=ReplyKeyboardRemove())
        
        # User management sub-menus
        elif message_text in ["📋 List All Users", "🔍 Search Users"]:
            if message_text == "📋 List All Users":
                await self.admin_user_mgmt.handle_user_list(update, context)
            else:
                await self.admin_user_mgmt.handle_user_search(update, context)
        
        elif message_text == "📊 User Statistics":
            await self.admin_user_mgmt.handle_user_statistics(update, context)
        
        elif message_text == "⬅️ Back to Admin Menu":
            await self.admin_command(update, context)
        
        # Search criteria handling
        elif message_text in ["Search by Name", "Search by Email", "Search by Company", 
                             "Search by Phone", "Show Companies Only", "Show B2B Users", 
                             "Show Active Users", "Show With Quotes"]:
            await self.admin_user_mgmt.handle_search_criteria(update, context)
    
    async def show_dynamics_sync_menu(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Show Dynamics 365 sync management menu"""
        if not Config.ENABLE_DYNAMICS_SYNC:
            await update.message.reply_text("Dynamics 365 integration is not enabled.")
            return
        
        # Get sync statistics
        stats = self.dynamics_integration.get_sync_statistics()
        
        message = "📊 **Dynamics 365 Sync Management**\n\n"
        message += f"**Sync Status:**\n"
        message += f"â€¢ Users Synced: {stats.get('synced_users', 0)}\n"
        message += f"â€¢ Users Pending: {stats.get('pending_users', 0)}\n"
        message += f"â€¢ Users with Errors: {stats.get('error_users', 0)}\n\n"
        message += f"â€¢ Quotes Synced: {stats.get('synced_quotes', 0)}\n"
        message += f"â€¢ Quotes Pending: {stats.get('pending_quotes', 0)}\n"
        message += f"â€¢ Quotes with Errors: {stats.get('error_quotes', 0)}\n\n"
        message += f"**Recent Activity (24h):**\n"
        message += f"â€¢ Total Syncs: {stats.get('syncs_24h', 0)}\n"
        message += f"â€¢ Errors: {stats.get('errors_24h', 0)}\n"
        
        # Check background sync status
        if self.dynamics_sync_task and not self.dynamics_sync_task.done():
            message += f"\n✅ Bidirectional sync is active"
        else:
            message += f"\nâš ï¸ Bidirectional sync is not running"
        
        keyboard = [
            ["ðŸ”„ Sync Pending Items"],
            ["🔍 View Sync Errors"],
            ["ðŸ‘¤ Sync Specific User"],
            ["ðŸ“„ Sync Specific Quote"],
            ["ðŸ”„ Force Full Sync"],
            ["â¬…ï¸ Back to Admin Menu"]
        ]
        reply_markup = ReplyKeyboardMarkup(keyboard, one_time_keyboard=True, resize_keyboard=True)
        
        await update.message.reply_text(
            message,
            reply_markup=reply_markup,
            parse_mode="Markdown"
        )
        
        # Store state for handling responses
        context.user_data['admin_dynamics_menu'] = True
    
    async def handle_dynamics_menu_selection(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle Dynamics 365 menu selections"""
        if not context.user_data.get('admin_dynamics_menu'):
            return
        
        message_text = update.message.text
        
        if message_text == "ðŸ”„ Sync Pending Items":
            await update.message.reply_text("ðŸ”„ Starting sync of pending items...")
            await self.dynamics_integration.sync_pending_entities()
            await update.message.reply_text("✅ Sync completed!")
            context.user_data['admin_dynamics_menu'] = False
            
        elif message_text == "🔍 View Sync Errors":
            errors = self.dynamics_integration.get_sync_errors(limit=10)
            if errors:
                error_msg = "âŒ **Recent Sync Errors:**\n\n"
                for error in errors[:5]:  # Show first 5
                    error_msg += f"â€¢ {error['entity_type']} {error['entity_id']}: {error['error_message'][:50]}...\n"
                await update.message.reply_text(error_msg, parse_mode="Markdown")
            else:
                await update.message.reply_text("✅ No recent sync errors!")
            context.user_data['admin_dynamics_menu'] = False
            
        elif message_text == "ðŸ‘¤ Sync Specific User":
            await update.message.reply_text("Enter the Telegram User ID to sync:")
            context.user_data['admin_dynamics_menu'] = False
            context.user_data['awaiting_dynamics_user_id'] = True
            
        elif message_text == "ðŸ“„ Sync Specific Quote":
            await update.message.reply_text("Enter the Quote ID to sync:")
            context.user_data['admin_dynamics_menu'] = False
            context.user_data['awaiting_dynamics_quote_id'] = True
            
        elif message_text == "ðŸ”„ Force Full Sync":
            await update.message.reply_text("ðŸ”„ Starting full bidirectional sync...")
            await self.dynamics_integration.sync_from_dynamics()
            await update.message.reply_text("✅ Full sync completed!")
            context.user_data['admin_dynamics_menu'] = False
            
        elif message_text == "â¬…ï¸ Back to Admin Menu":
            context.user_data['admin_dynamics_menu'] = False
            await self.admin_command(update, context)
    
    async def show_admin_statistics(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Show admin statistics"""
        # Get various statistics
        stats = self.db.execute_query(
            """
            SELECT
                (SELECT COUNT(*) FROM users) as total_users,
                (SELECT COUNT(*) FROM users WHERE last_activity > DATE_SUB(NOW(), INTERVAL 7 DAY)) as active_users_week,
                (SELECT COUNT(*) FROM users WHERE last_activity > DATE_SUB(NOW(), INTERVAL 30 DAY)) as active_users_month,
                (SELECT COUNT(*) FROM quotations) as total_quotes,
                (SELECT COUNT(*) FROM quotations WHERE created_at > DATE_SUB(NOW(), INTERVAL 7 DAY)) as quotes_week,
                (SELECT COUNT(*) FROM quotations WHERE status = 'accepted') as accepted_quotes,
                (SELECT COUNT(*) FROM conversation_logs WHERE created_at > DATE_SUB(NOW(), INTERVAL 24 HOUR)) as messages_24h,
                (SELECT SUM(total_price) FROM quotations WHERE status = 'accepted') as total_revenue
            """,
            fetch=True,
        )
        
        if stats and stats[0]:
            s = stats[0]
            report = f"""📊 Admin Statistics Dashboard

ðŸ‘¥ Users:
â€¢ Total Users: {s['total_users']}
â€¢ Active (7 days): {s['active_users_week']}
â€¢ Active (30 days): {s['active_users_month']}

📋 Quotes:
â€¢ Total Quotes: {s['total_quotes']}
â€¢ This Week: {s['quotes_week']}
â€¢ Accepted: {s['accepted_quotes']}
â€¢ Success Rate: {(s['accepted_quotes'] / s['total_quotes'] * 100) if s['total_quotes'] > 0 else 0:.1f}%

ðŸ’¬ Activity:
â€¢ Messages (24h): {s['messages_24h']}
â€¢ Avg Daily Users: {s['active_users_week'] / 7:.1f}

ðŸ’° Revenue:
â€¢ Total Accepted: â‚¬{s['total_revenue'] or 0:,.2f}
â€¢ Average Quote: â‚¬{(s['total_revenue'] / s['accepted_quotes']) if s['accepted_quotes'] > 0 else 0:,.2f}"""
            
            await update.message.reply_text(report)
    
