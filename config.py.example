    DYNAMICS_ACCOUNT_ENTITY = os.getenv("DYNAMICS_ACCOUNT_ENTITY", "accounts")
    DYNAMICS_ACTIVITY_ENTITY = os.getenv("DYNAMICS_ACTIVITY_ENTITY", "tasks")
    
    # Dynamics sync intervals (in seconds)
    DYNAMICS_SYNC_INTERVAL = int(os.getenv("DYNAMICS_SYNC_INTERVAL", "300"))  # 5 minutes
    DYNAMICS_RETRY_INTERVAL = int(os.getenv("DYNAMICS_RETRY_INTERVAL", "60"))  # 1 minute
    DYNAMICS_MAX_RETRIES = int(os.getenv("DYNAMICS_MAX_RETRIES", "3"))
    
    # Company settings
    COMPANY_NAME = os.getenv("COMPANY_NAME", "Stretch Group")
    COMPANY_EMAIL = os.getenv("COMPANY_EMAIL", "info@stretchgroup.be")
    COMPANY_PHONE = os.getenv("COMPANY_PHONE", "+32 485 48 30 35")
    COMPANY_ADDRESS = os.getenv("COMPANY_ADDRESS", "Your Company Address")
    COMPANY_WEBSITE = os.getenv("COMPANY_WEBSITE", "https://stretchgroup.be")
    
    # Company branding
    COMPANY_PRIMARY_COLOR = os.getenv("COMPANY_PRIMARY_COLOR", "#E30613")
    COMPANY_SECONDARY_COLOR = os.getenv("COMPANY_SECONDARY_COLOR", "#000000")
    COMPANY_LOGO_PATH = os.getenv("COMPANY_LOGO_PATH", "stretch_logo.png")
    
    # Quote settings
