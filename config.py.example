    # Features
    ENABLE_PDF_GENERATION = os.getenv("ENABLE_PDF_GENERATION", "true").lower() == "true"
    ENABLE_EMAIL_SENDING = os.getenv("ENABLE_EMAIL_SENDING", "true").lower() == "true"
    ENABLE_AI_CHAT = os.getenv("ENABLE_AI_CHAT", "true").lower() == "true"
    
    # WhatsApp Integration (future)
    WHATSAPP_API_URL = os.getenv("WHATSAPP_API_URL")
    WHATSAPP_API_TOKEN = os.getenv("WHATSAPP_API_TOKEN")
    WHATSAPP_PHONE_NUMBER_ID = os.getenv("WHATSAPP_PHONE_NUMBER_ID")
    
    # Development settings
    DEBUG_MODE = os.getenv("DEBUG_MODE", "false").lower() == "true"
    
    @staticmethod
    def validate_config():
        """Validate configuration including Dynamics 365 settings"""
        errors = []
        
        db_config = Config.get_database_config()
        required_db_fields = ["host", "database", "user", "password"]
        for field in required_db_fields:
            if not db_config.get(field):
                errors.append(f"Missing required database configuration: {field.upper()}")
        
        if not Config.BOT_TOKEN:
            errors.append("Missing required TELEGRAM_BOT_TOKEN")
        
        # Validate Entra ID configuration
        if Config.ENABLE_EMAIL_SENDING:
            if not Config.AZURE_TENANT_ID:
                errors.append("Missing required AZURE_TENANT_ID for email")
            if not Config.AZURE_CLIENT_ID:
                errors.append("Missing required AZURE_CLIENT_ID for email")
            if not Config.AZURE_CLIENT_SECRET:
                errors.append("Missing required AZURE_CLIENT_SECRET for email")
            if not Config.EMAIL_FROM:
                errors.append("Missing required EMAIL_FROM for email")
        
        # Validate Dynamics 365 configuration
        if Config.ENABLE_DYNAMICS_SYNC:
            if not Config.DYNAMICS_URL:
                errors.append("Missing required DYNAMICS_URL for Dynamics 365")
            if not Config.DYNAMICS_CLIENT_ID:
                errors.append("Missing required DYNAMICS_CLIENT_ID for Dynamics 365")
            if not Config.DYNAMICS_CLIENT_SECRET:
                errors.append("Missing required DYNAMICS_CLIENT_SECRET for Dynamics 365")
            if not Config.DYNAMICS_TENANT_ID:
                errors.append("Missing required DYNAMICS_TENANT_ID for Dynamics 365")
        
        if errors:
            raise ValueError("Configuration errors:\n" + "\n".join(f"- {error}" for error in errors))
        
        logger = logging.getLogger(__name__)
        logger.info("✅ Configuration validation passed")
        logger.info(f"🏢 Company: {Config.COMPANY_NAME}")
        logger.info(f"🗄️ Database: {db_config['host']}/{db_config['database']}")
        logger.info(f"🤖 AI Model: {Config.DEPLOYMENT_NAME}")
        logger.info(f"📧 Email: Entra ID configured ({Config.EMAIL_FROM})")
        
        if Config.ENABLE_DYNAMICS_SYNC:
            logger.info(f"🔄 Dynamics 365: Enabled ({Config.DYNAMICS_URL})")
            logger.info(f"   - Sync Quotes: {Config.DYNAMICS_SYNC_QUOTES}")
            logger.info(f"   - Sync Users: {Config.DYNAMICS_SYNC_USERS}")
            logger.info(f"   - Create Activities: {Config.DYNAMICS_CREATE_ACTIVITIES}")
        else:
            logger.info("🔄 Dynamics 365: Disabled")
    
    @staticmethod
    def get_dynamics_config():
        """Get Dynamics 365 specific configuration"""
        return {
            "url": Config.DYNAMICS_URL,
            "tenant_id": Config.DYNAMICS_TENANT_ID,
            "client_id": Config.DYNAMICS_CLIENT_ID,
            "client_secret": Config.DYNAMICS_CLIENT_SECRET,
            "sync_quotes": Config.DYNAMICS_SYNC_QUOTES,
            "sync_users": Config.DYNAMICS_SYNC_USERS,
            "create_activities": Config.DYNAMICS_CREATE_ACTIVITIES,
            "entities": {
                "quote": Config.DYNAMICS_QUOTE_ENTITY,
                "contact": Config.DYNAMICS_CONTACT_ENTITY,
                "account": Config.DYNAMICS_ACCOUNT_ENTITY,
                "activity": Config.DYNAMICS_ACTIVITY_ENTITY
            },
            "sync_interval": Config.DYNAMICS_SYNC_INTERVAL,
            "retry_interval": Config.DYNAMICS_RETRY_INTERVAL,
            "max_retries": Config.DYNAMICS_MAX_RETRIES
        }