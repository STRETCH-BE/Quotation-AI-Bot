"""
Configuration management for Stretch Ceiling Bot
ENHANCED: Dynamics 365 integration configuration
"""
import os
import logging
from typing import List
from dotenv import load_dotenv

# Load environment variables
try:
    load_dotenv()
    print("✅ Environment variables loaded from .env file")
except ImportError:
    print("⚠️ python-dotenv not installed. Using system environment variables.")

# Security Filter for logging
class SensitiveDataFilter(logging.Filter):
    """Filter to redact sensitive data from logs while preserving data types"""
    
    def __init__(self):
        super().__init__()
        self.patterns = [
            (r"bot\d+:[A-Za-z0-9_-]{35,}", "[BOT_TOKEN]"),
            (r"Bearer [A-Za-z0-9_-]+", "[BEARER_TOKEN]"),
            (r"password=[^&\s]+", "password=[REDACTED]"),
            (r"AAF[A-Za-z0-9_-]{33,}", "[TELEGRAM_TOKEN]"),
            (r"[a-zA-Z0-9]{8}Q~[a-zA-Z0-9._~-]{32,}", "[CLIENT_SECRET]"),
            (r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}", "[UUID]"),
        ]
    
    def filter(self, record):
        import re
        if hasattr(record, "msg"):
            msg = str(record.msg)
            for pattern, replacement in self.patterns:
                msg = re.sub(pattern, replacement, msg)
            record.msg = msg
        
        if hasattr(record, "args") and record.args:
            new_args = []
            for arg in record.args:
                if isinstance(arg, str):
                    new_arg = arg
                    for pattern, replacement in self.patterns:
                        new_arg = re.sub(pattern, replacement, new_arg)
                    new_args.append(new_arg)
                else:
                    new_args.append(arg)
            record.args = tuple(new_args)
        
        return True

# Enhanced logging setup
def setup_logging():
    log_level = getattr(logging, os.getenv("LOG_LEVEL", "INFO").upper())
    log_format = "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    
    sensitive_filter = SensitiveDataFilter()
    
    handlers = []
    console_handler = logging.StreamHandler()
    console_handler.setFormatter(logging.Formatter(log_format))
    console_handler.addFilter(sensitive_filter)
    handlers.append(console_handler)
    
    if os.getenv("LOG_TO_FILE", "true").lower() == "true":
        log_file = os.getenv("LOG_FILE", "enhanced_multi_ceiling_bot.log")
        file_handler = logging.FileHandler(log_file)
        file_handler.setFormatter(logging.Formatter(log_format))
        file_handler.addFilter(sensitive_filter)
        handlers.append(file_handler)
    
    debug_handler = logging.FileHandler("bot_debug.log")
    debug_handler.setFormatter(logging.Formatter(log_format))
    debug_handler.setLevel(logging.DEBUG)
    debug_handler.addFilter(sensitive_filter)
    handlers.append(debug_handler)
    
    logging.basicConfig(level=log_level, format=log_format, handlers=handlers)
    
    logging.getLogger("httpx").setLevel(logging.WARNING)
    logging.getLogger("telegram").setLevel(logging.INFO)
    logging.getLogger("telegram.ext").setLevel(logging.INFO)
    logging.getLogger("urllib3").setLevel(logging.WARNING)
    logging.getLogger("httpcore").setLevel(logging.WARNING)
    logging.getLogger("msal").setLevel(logging.INFO)

# Configuration class
class Config:
    """Configuration management with Dynamics 365 integration"""
    
