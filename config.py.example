    DYNAMICS_CREATE_ACTIVITIES = os.getenv("DYNAMICS_CREATE_ACTIVITIES", "true").lower() == "true"
    
    # Dynamics entity mappings
    DYNAMICS_QUOTE_ENTITY = os.getenv("DYNAMICS_QUOTE_ENTITY", "quotes")
