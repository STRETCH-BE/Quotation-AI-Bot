    MAX_CEILINGS_PER_QUOTE = int(os.getenv("MAX_CEILINGS_PER_QUOTE", "10"))
    QUOTE_SESSION_TIMEOUT_HOURS = int(os.getenv("QUOTE_SESSION_TIMEOUT_HOURS", "2"))
    
    # Admin settings
    ADMIN_USER_IDS = [int(id.strip()) for id in os.getenv("ADMIN_USER_IDS", "").split(",") if id.strip()]
    
