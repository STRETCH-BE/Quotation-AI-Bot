            "password": os.getenv("MYSQL_PASSWORD", ""),
            "port": int(os.getenv("MYSQL_PORT", "3306")),
            "charset": "utf8mb4",
            "autocommit": True,
            "connect_timeout": 20,
            "ssl": {"fake_flag_to_enable_tls": True},
        }
        return config
    
